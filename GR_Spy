    b.BackgroundTransparency = ButtonTransp; b.TextColor3 = Color3.new(1,1,1); b.TextTransparency = TextTransp
    b.Text = txt; b.Font = "SourceSansBold"; b.Parent = ActionScroll
    Instance.new("UICorner", b)
    
    b.MouseButton1Click:Connect(function()
        if Disparando then return end -- Bloqueia se já estiver processando
        Disparando = true
        func()
        task.wait(0.2) -- Pequeno delay para evitar double-click
        Disparando = false
    end)
end

local function selectObject(obj, type)
    ObjetoSelecionado = obj; ActionMenu.Visible = true
    for _, v in pairs(ActionScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local L = LangTable[CurrentLang]
    
    if type == "Remote" then
        CodeDisplay.Visible = true
        local d = RemotesLog[obj]
        local argsStr = FormatValue(d.Args)
        local scriptBase = "local args = " .. argsStr .. "\ngame." .. obj:GetFullName() .. ":" .. d.Method .. "(unpack(args))"
        local loopBase = "while true do task.wait()\n    local args = " .. argsStr .. "\n    game." .. obj:GetFullName() .. ":" .. d.Method .. "(unpack(args))\nend"
        CodeLabel.Text = "-- GR_Spy\n" .. scriptBase
        
        addActionBtn(L.Run, function() 
            RemoteCounter = RemoteCounter - 1; d.Count = d.Count + 1; d.Order = RemoteCounter
            task.spawn(function() if d.Method == "FireServer" then obj:FireServer(unpack(d.Args)) else obj:InvokeServer(unpack(d.Args)) end end)
        end, true)
        
        if LoopingRemotes[obj] then
            addActionBtn(L.StopLoop, function() LoopingRemotes[obj] = nil; selectObject(obj, "Remote") end, false)
        else
            addActionBtn(L.RunLoop, function() LoopingRemotes[obj] = true; selectObject(obj, "Remote") end, true)
        end
        
        addActionBtn(L.CopyScript, function() setclipboard(scriptBase) end)
        addActionBtn(L.CopyLoop, function() setclipboard(loopBase) end)
    else
        CodeDisplay.Visible = false
        if type == "Prompt" then 
            addActionBtn(L.FireP, function() fireproximityprompt(obj) end, true)
        elseif type == "Touched" then 
            addActionBtn(L.FireT, function() 
                firetouchinterest(LocalPlayer.Character.HumanoidRootPart, obj, 0)
                task.wait(0.05)
                firetouchinterest(LocalPlayer.Character.HumanoidRootPart, obj, 1) 
            end, true) 
        end
        addActionBtn(L.Teleport, function() 
            local p = obj:IsA("BasePart") and obj.CFrame or obj.Parent:GetPivot()
            LocalPlayer.Character:PivotTo(p) 
        end)
    end
    addActionBtn(L.CopyPath, function() setclipboard(obj:GetFullName()) end)
end

task.spawn(function()
    while true do
        RunService.Heartbeat:Wait()
        for remote, isLooping in pairs(LoopingRemotes) do
            if isLooping then
                local d = RemotesLog[remote]
                if d then
                    RemoteCounter = RemoteCounter - 1; d.Count = d.Count + 1; d.Order = RemoteCounter
                    task.spawn(function() pcall(function() if d.Method == "FireServer" then remote:FireServer(unpack(d.Args)) else remote:InvokeServer(unpack(d.Args)) end end) end)
                end
            end
        end
    end
end)

local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod(); local args = {...}
    if (method == "FireServer" or method == "InvokeServer") and not checkcaller() then
        RemoteCounter = RemoteCounter - 1
        if not RemotesLog[self] then 
            RemotesLog[self] = {Method = method, Args = args, Count = 1, Order = RemoteCounter}
            table.insert(RemotesOrdem, 1, self)
        else 
            RemotesLog[self].Count = RemotesLog[self].Count + 1; RemotesLog[self].Args = args; RemotesLog[self].Order = RemoteCounter
        end
    end
    return old(self, ...)
end); setreadonly(mt, true)

