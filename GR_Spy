local function addActionBtn(txt, func, isGreen)
    local b = Instance.new("TextButton")
    -- Ajustado posição X para 5 (um pouco mais para a esquerda/centro)
    b.Size = UDim2.new(1, -10, 0, 30); b.Position = UDim2.new(0, 5, 0, 0)
