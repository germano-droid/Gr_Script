local function MakeDraggable(frame, parent)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = parent.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            parent.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function FormatValue(v)
    if typeof(v) == "string" then return '"' .. v .. '"'
    elseif typeof(v) == "Instance" then return 'game.' .. v:GetFullName()
    elseif typeof(v) == "Vector3" then return "Vector3.new(" .. string.format("%.3f, %.3f, %.3f", v.X, v.Y, v.Z) .. ")"
    elseif typeof(v) == "table" then
        local s = "{"
        for i, val in pairs(v) do s = s .. "[" .. FormatValue(i) .. "] = " .. FormatValue(val) .. ", " end
        return (#s > 1 and s:sub(1,#s-2) or "{") .. "}"
    end
    return tostring(v)
end

