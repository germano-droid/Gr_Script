local function createToggle(parent, name, posY, isMini, callback)
    local label = Instance.new("TextLabel", parent)
    label.Text = name
    label.TextColor3 = isMini and Color3.fromRGB(180, 180, 180) or Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamBold
    label.TextSize = isMini and 7 or 10
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local bg = Instance.new("Frame", parent)
    bg.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", bg)
    circle.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    if isMini then
        label.Size = UDim2.new(0, 45, 0, 18)
        label.Position = UDim2.new(0, 10, 0, posY)
        bg.Size = UDim2.new(0, 22, 0, 10)
        bg.Position = UDim2.new(0, 58, 0, posY + 4)
        circle.Size = UDim2.new(0, 6, 0, 6)
        circle.Position = UDim2.new(0, 2, 0.5, -3)
    else
        label.Size = UDim2.new(0, 60, 0, 18)
        label.Position = UDim2.new(0, 10, 0, posY)
        bg.Size = UDim2.new(0, 38, 0, 16)
        bg.Position = UDim2.new(1, -45, 0, posY + 1)
        circle.Size = UDim2.new(0, 12, 0, 12)
        circle.Position = UDim2.new(0, 2, 0.5, -6)
    end

    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        TweenService:Create(bg, TweenInfo.new(0.15), {BackgroundColor3 = active and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(100, 0, 0)}):Play()
        local posOn = isMini and UDim2.new(1, -8, 0.5, -3) or UDim2.new(1, -14, 0.5, -6)
        local posOff = UDim2.new(0, 2, 0.5, isMini and -3 or -6)
        TweenService:Create(circle, TweenInfo.new(0.15), {Position = active and posOn or posOff}):Play()
        
        if name == "AUTO FARM" and not active and tweenAtual then
            tweenAtual:Cancel()
        end
        callback(active)
    end)
end

