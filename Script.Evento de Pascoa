local function getEggs()
    local list = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        local n = obj.Name:lower()
        if (n:find("egg") or n:find("pascoa") or n:find("easter")) and not n:find("shop") then
            if not obj:IsDescendantOf(charactersFolder) and not obj:IsDescendantOf(player.Backpack) and not ovosIgnorados[obj] then
                if obj:IsA("BasePart") or obj:IsA("Model") then table.insert(list, obj) end
            end
        end
    end
    return list
end

local function tweenTo(pos)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not farmAtivo then return end
    if tweenAtual then tweenAtual:Cancel() end
    tweenAtual = TweenService:Create(hrp, TweenInfo.new((hrp.Position - pos).Magnitude/velocidadeTween, Enum.EasingStyle.Linear), {CFrame = CFrame.new(pos)})
    tweenAtual:Play()
    return tweenAtual
end

