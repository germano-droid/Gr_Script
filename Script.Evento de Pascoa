        if espAtivo then
            for _, egg in pairs(getEggs()) do
                if not espCache[egg] then
                    local p = egg:IsA("BasePart") and egg or egg:FindFirstChildWhichIsA("BasePart", true)
                    if p then
                        local bb = Instance.new("BillboardGui", gui); bb.Adornee = p; bb.Size = UDim2.new(0, 100, 0, 20); bb.AlwaysOnTop = true
                        local t = Instance.new("TextLabel", bb); t.Size = UDim2.new(1,0,1,0); t.BackgroundTransparency = 1; t.TextColor3 = Color3.new(0,1,0); t.TextScaled = true; t.Text = "🥚 "..egg.Name
                        espCache[egg] = bb
                    end
                end
            end
            for e, g in pairs(espCache) do if not e or not e.Parent or e:IsDescendantOf(charactersFolder) or ovosIgnorados[e] then g:Destroy(); espCache[e] = nil end end
        else
            for _, g in pairs(espCache) do g:Destroy() end; espCache = {}
        end
        task.wait(0.5)
    end
end)
