-- LOOP DE FARM COM PROTEÇÃO CONTRA NPC SUMINDO
----------------------------------------------------
task.spawn(function()
    while true do
        task.wait(0.2)
        if farmAtivo then
            local eggs = getEggs()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            
            if hrp and #eggs > 0 then
                table.sort(eggs, function(a, b) return (hrp.Position - a:GetPivot().Position).Magnitude < (hrp.Position - b:GetPivot().Position).Magnitude end)
                local alvo = eggs[1]
                local tw = tweenTo(alvo:GetPivot().Position)
                
                if tw then
                    local start = tick()
                    local done = false
                    local c; c = tw.Completed:Connect(function() done = true end)
                    while not done and farmAtivo and alvo.Parent do
                        if tick() - start > tempoLimiteOvo then ovosIgnorados[alvo] = true; tw:Cancel(); break end
                        task.wait(0.1)
                    end
                    if c then c:Disconnect() end
                    
                    -- INTERAÇÃO COM NPC (Pode ser chamado após pegar ovo)
                    pcall(function()
                        local npc = workspace:FindFirstChild("Pirate Adventurer", true)
                        if npc and (hrp.Position - npc:GetPivot().Position).Magnitude < 20 then
                            replicatedStorage.Modules.Net["RF/EasterServiceRF"]:InvokeServer("NPC.TravelingQuest", npc)
                        end
                    end)
                end
            elseif hrp then
                local ilhas = mapFolder:GetChildren()
                local alvoIlha, dMin = nil, math.huge
                for _, i in pairs(ilhas) do
                    if not ilhasVisitadas[i] and (i:IsA("Model") or i:IsA("BasePart")) then
                        local d = (hrp.Position - i:GetPivot().Position).Magnitude
                        if d < dMin then dMin = d; alvoIlha = i end
                    end
                end
                if not alvoIlha then ilhasVisitadas = {} else
                    ilhasVisitadas[alvoIlha] = true
                    local tw = tweenTo(alvoIlha:GetPivot().Position + Vector3.new(0, alturaViagem, 0))
                    if tw then
                        local pronto = false
                        local c = tw.Completed:Connect(function() pronto = true end)
                        while not pronto and farmAtivo and #getEggs() == 0 do task.wait(0.1) end
                        if c then c:Disconnect() end
                    end
                end
            end
        end
    end
end)

